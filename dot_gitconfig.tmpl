[core]
  excludesfile = ~/.gitignore
  editor = code --wait
  pager = less -F -X
  hooksPath = /home/albert/.git-hooks

[user]
  name = Albert Callarisa
  email = {{ .email }}
{{- if eq .email "albert@diagrid.io" }}
  signingkey = 450F38BCAA761685
{{- end }}

{{- if eq .email "albert@diagrid.io" }}
[commit]
  gpgsign = true
{{- end }}

[alias]
  st = status -bs
  pr = pull --rebase
  car = commit --amend --reset-author
  ci= commit
  co= checkout
  l=log --graph --pretty=format:'%Cgreen%h%Cblue%d%Creset %s %Cred%an%Creset'
  up = "!f(){ \n  set -euo pipefail\n  echo \"🔄 Fetching all remotes...\"\n  git fetch --all --prune --tags\n\n  echo \"⚙️  Syncing local branches with origin...\"\n  for b in $(git for-each-ref --format \"%(refname:lstrip=3)\" refs/remotes/origin | grep -vE \"HEAD$\"); do\n    if git show-ref --verify --quiet \"refs/heads/$b\"; then\n      git branch -f \"$b\" \"origin/$b\"\n    else\n      git branch --track \"$b\" \"origin/$b\" 2>/dev/null || true\n    fi\n  done\n\n  echo \"🚀 Mirroring all upstream branches & tags to origin (atomic, force-with-lease)...\"\n  refs=$(git for-each-ref --format \"refs/remotes/upstream/%(refname:lstrip=3):refs/heads/%(refname:lstrip=3)\" refs/remotes/upstream | grep -vE \"HEAD$\")\n  git push --atomic --force-with-lease origin $refs refs/tags/*\n\n  echo \"✅ Local branches now track origin; origin fully mirrors upstream.\"\n}; f"

[pull]
  rebase = false

[push]
  default = current
  autoSetupRemote = true

[apply]
  whitespace = warn

[color]
  diff = auto
  status = auto
  branch = auto
  ui = always

[filter "hawser"]
  clean = git hawser clean %f
  smudge = git hawser smudge %f
  required = true
[gc]
  auto = 1

[diff]
  tool = default-difftool

[difftool "default-difftool"]
  cmd = code --wait --diff $LOCAL $REMOTE

[color "diff"]
  meta = yellow bold
  commit = green bold
  frag = magenta bold
  old = red bold
  new = green bold
  whitespace = red reverse
[color "diff-highlight"]
  oldNormal = red bold
  oldHighlight = "red bold 52"
  newNormal = "green bold"
  newHighlight = "green bold 22"
[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green
[color "status"]
  added = yellow
  changed = green
  untracked = cyan
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  required = true
  process = git-lfs filter-process
[url "git@github.com:"]
  insteadOf = https://github.com/
[format]
	signoff = true
[rerere]
	enabled = true
